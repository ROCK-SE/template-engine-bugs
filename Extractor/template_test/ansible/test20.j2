vars:
    people_names:
      - first_name: tom
        last_name: hardy
  tasks:
    - set_fact:
        people_full_names: "{{ people_full_names|default([]) +
                               [item|combine({'full_name': full_name})] }}"
      loop: "{{ people_names }}"
      vars:
        full_name: "{{item.first_name}} {{ item.last_name }}"

    - debug:
        var: people_full_names